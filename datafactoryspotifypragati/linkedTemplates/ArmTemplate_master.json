{
	"$schema": "http://schema.management.azure.com/schemas/2015-01-01/deploymentTemplate.json#",
	"contentVersion": "1.0.0.0",
	"parameters": {
		"factoryName": {
			"type": "string",
			"metadata": "Data Factory name",
			"defaultValue": "datafactoryspotifypragati"
		},
		"AzureDataLakeSpotify1_accountKey": {
			"type": "secureString",
			"metadata": "Secure string for 'accountKey' of 'AzureDataLakeSpotify1'"
		},
		"AzureSqlSpotifyDatabase1_password": {
			"type": "secureString",
			"metadata": "Secure string for 'password' of 'AzureSqlSpotifyDatabase1'"
		},
		"AzureDataLakeSpotify1_properties_typeProperties_url": {
			"type": "string",
			"defaultValue": "https://datalakespotifypragati.dfs.core.windows.net/"
		},
		"AzureSqlSpotifyDatabase1_properties_typeProperties_server": {
			"type": "string",
			"defaultValue": "sql-spotify-pragati.database.windows.net"
		},
		"AzureSqlSpotifyDatabase1_properties_typeProperties_database": {
			"type": "string",
			"defaultValue": "dbSpotifyPragati"
		},
		"AzureSqlSpotifyDatabase1_properties_typeProperties_userName": {
			"type": "string",
			"defaultValue": "adminpragati"
		},
		"containerUri": {
			"type": "string",
			"metadata": "URI to storage account containing linked ARM templates"
		},
		"containerSasToken": {
			"type": "string",
			"metadata": "Sas token to storage account containing linked ARM templates"
		}
	},
	"variables": {
		"factoryId": "[concat('Microsoft.DataFactory/factories/', parameters('factoryName'))]"
	},
	"resources": [
		{
			"name": "datafactoryspotifypragati_ArmTemplate_0",
			"type": "Microsoft.Resources/deployments",
			"apiVersion": "2024-03-01",
			"properties": {
				"mode": "incremental",
				"templateLink": {
					"uri": "[concat(parameters('containerUri'), '/ArmTemplate_0.json', parameters('containerSasToken'))]",
					"contentVersion": "1.0.0.0"
				},
				"parameters": {
					"factoryName": {
						"value": "[parameters('factoryName')]"
					},
					"AzureDataLakeSpotify1_accountKey": {
						"value": "[parameters('AzureDataLakeSpotify1_accountKey')]"
					},
					"AzureSqlSpotifyDatabase1_password": {
						"value": "[parameters('AzureSqlSpotifyDatabase1_password')]"
					},
					"AzureDataLakeSpotify1_properties_typeProperties_url": {
						"value": "[parameters('AzureDataLakeSpotify1_properties_typeProperties_url')]"
					},
					"AzureSqlSpotifyDatabase1_properties_typeProperties_server": {
						"value": "[parameters('AzureSqlSpotifyDatabase1_properties_typeProperties_server')]"
					},
					"AzureSqlSpotifyDatabase1_properties_typeProperties_database": {
						"value": "[parameters('AzureSqlSpotifyDatabase1_properties_typeProperties_database')]"
					},
					"AzureSqlSpotifyDatabase1_properties_typeProperties_userName": {
						"value": "[parameters('AzureSqlSpotifyDatabase1_properties_typeProperties_userName')]"
					}
				}
			},
			"dependsOn": []
		}
	]
}